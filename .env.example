# ============================================
# KaiserBot - Configurações de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# API NVIDIA (para IA) - opcional, Groq é gratuito
NVIDIA_API_KEY=nvapi-seu-token-aqui

# API Groq (alternativa gratuita) - https://console.groq.com/keys
GROQ_API_KEY=

# API VexAPI (vexapicom.br)
VEX_API_KEY=

# Chave da API SMM (revisionsmm.com)
SMM_API_KEY=