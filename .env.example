# ============================================
# Abyss - Configurações de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# API Groq (gratuita) - https://console.groq.com/keys
GROQ_API_KEY=

# API VexAPI (vexapicom.br)
VEX_API_KEY=

# API Clash Royale (Supercell) - https://developer.clashroyale.com
CLASH_ROYALE_API_KEY=

# Chave da API SMM (revisionsmm.com)
SMM_API_KEY=

# Token do GitHub para uploads de mídia (comando !menuedicao e similares)
# Gere em: https://github.com/settings/tokens
GITHUB_UPLOAD_TOKEN=